# ==============================================================================
# Riverlands Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values
# See setup.md for detailed instructions on obtaining each value

# ------------------------------------------------------------------------------
# Supabase (Required)
# ------------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------------
# Resend - Email Service (Required)
# ------------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key

# Email addresses (optional - defaults shown)
FROM_EMAIL=Riverlands <noreply@riverlands.org>
ADMIN_EMAIL=admin@riverlands.org

# ------------------------------------------------------------------------------
# Cloudinary - Image Hosting (Required)
# ------------------------------------------------------------------------------
# Get these from: https://console.cloudinary.com/settings/c-<your-cloud>/api-keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ------------------------------------------------------------------------------
# Site URLs (Required)
# ------------------------------------------------------------------------------
# Your production domain (used for canonical URLs, sitemap, emails, admin panel)
NEXT_PUBLIC_SITE_URL=https://riverlands.org

# ------------------------------------------------------------------------------
# Upstash Redis - Rate Limiting (Required for production)
# ------------------------------------------------------------------------------
# Get these from: https://console.upstash.com/ (create a Redis database)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# ------------------------------------------------------------------------------
# Google Analytics 4 (Optional)
# ------------------------------------------------------------------------------
# Get your measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ------------------------------------------------------------------------------
# Cron Jobs (Required for scheduled posts)
# ------------------------------------------------------------------------------
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ------------------------------------------------------------------------------
# Development Overrides
# ------------------------------------------------------------------------------
# Uncomment for local development:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
